{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "battle.schema.json",
  "title": "Battle Atlas track data",
  "type": "object",
  "required": [
    "name",
    "startTime",
    "endTime",
    "units"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "startTime": {
      "type": "number",
      "minimum": 0
    },
    "endTime": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "t0",
          "t1"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": [
              "artillery_fire",
              "musketry"
            ]
          },
          "t0": {
            "type": "number",
            "minimum": 0
          },
          "t1": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "unitId": {
            "type": "string",
            "minLength": 1
          },
          "x": {
            "type": "number"
          },
          "z": {
            "type": "number"
          },
          "x2": {
            "type": "number"
          },
          "z2": {
            "type": "number"
          },
          "confidence": {
            "enum": [
              "documented",
              "inferred",
              "unknown"
            ]
          },
          "citation": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        },
        "oneOf": [
          {
            "required": [
              "unitId"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "x"
                  ]
                },
                {
                  "required": [
                    "z"
                  ]
                },
                {
                  "required": [
                    "x2"
                  ]
                },
                {
                  "required": [
                    "z2"
                  ]
                }
              ]
            }
          },
          {
            "required": [
              "x",
              "z",
              "x2",
              "z2"
            ],
            "not": {
              "required": [
                "unitId"
              ]
            }
          }
        ],
        "if": {
          "properties": {
            "confidence": {
              "const": "documented"
            }
          },
          "required": [
            "confidence"
          ]
        },
        "then": {
          "required": [
            "citation"
          ],
          "properties": {
            "citation": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "required": [
        "windTowardDeg",
        "windMps"
      ],
      "additionalProperties": false,
      "properties": {
        "windTowardDeg": {
          "type": "number"
        },
        "windMps": {
          "type": "number",
          "minimum": 0
        },
        "confidence": {
          "enum": [
            "documented",
            "inferred",
            "unknown"
          ]
        },
        "citation": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "if": {
        "properties": {
          "confidence": {
            "const": "documented"
          }
        },
        "required": [
          "confidence"
        ]
      },
      "then": {
        "required": [
          "citation"
        ],
        "properties": {
          "citation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "side",
          "frontage_m",
          "depth_m",
          "keyframes"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "side": {
            "enum": [
              "union",
              "confederate"
            ]
          },
          "frontage_m": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "depth_m": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "regiments": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "parent": {
            "type": "string",
            "minLength": 1
          },
          "keyframes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "t",
                "x",
                "z",
                "facing",
                "formation",
                "strength"
              ],
              "additionalProperties": false,
              "properties": {
                "t": {
                  "type": "number",
                  "minimum": 0
                },
                "x": {
                  "type": "number"
                },
                "z": {
                  "type": "number"
                },
                "facing": {
                  "type": "number"
                },
                "formation": {
                  "enum": [
                    "column",
                    "line",
                    "skirmish",
                    "scattered",
                    "routed"
                  ]
                },
                "strength": {
                  "type": "number",
                  "minimum": 0
                },
                "confidence": {
                  "enum": [
                    "documented",
                    "inferred",
                    "unknown"
                  ]
                },
                "citation": {
                  "type": "string"
                }
              },
              "if": {
                "properties": {
                  "confidence": {
                    "const": "documented"
                  }
                },
                "required": [
                  "confidence"
                ]
              },
              "then": {
                "required": [
                  "citation"
                ],
                "properties": {
                  "citation": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}